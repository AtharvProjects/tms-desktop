datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Trip {
  id               String   @id @default(uuid())
  tripNo           String   @unique
  tripDate         DateTime @default(now())
  
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  
  partyId          String
  party            Party    @relation(fields: [partyId], references: [id])
  
  driverId         String?
  driver           Driver?  @relation(fields: [driverId], references: [id])

  from             String
  to               String
  material         String?
  sizeWeight       String?
  
  reportDate       DateTime?
  loadingDate      DateTime?
  unloadingDate    DateTime?
  
  billingType      String   @default("Fixed")
  freightAmount    Float    @default(0)
  
  dieselAmount     Float    @default(0)
  liquidDiesel     Float    @default(0)
  driverCash       Float    @default(0)
  labourCharges    Float    @default(0)
  permissionCharges Float   @default(0)
  toll             Float    @default(0)
  advance          Float    @default(0)
  extraCharges     Float    @default(0)
  holdingDays      Int      @default(0)
  
  podStatus        String   @default("Pending") // Pending, Received, Submitted
  paymentStatus    String   @default("Pending") // Pending, Partial, Paid
  
  notes            String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  invoices         Invoice[]
}

model Vehicle {
  id               String   @id @default(uuid())
  vehicleNumber    String   @unique
  vehicleType      String
  capacity         String?
  
  insuranceExpiry  DateTime?
  fitnessExpiry    DateTime?
  permitExpiry     DateTime?
  pollutionExpiry  DateTime?
  
  driverId         String?
  driver           Driver?  @relation("VehicleDriver", fields: [driverId], references: [id])
  
  status           String   @default("Active")
  notes            String?
  
  trips            Trip[]
  dieselLogs       DieselLog[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Driver {
  id               String   @id @default(uuid())
  driverName       String
  mobileNumber     String
  licenseNumber    String?
  licenseExpiry    DateTime?
  aadhaarNumber    String?
  panNumber        String?
  
  salary           Float    @default(0)
  advanceBalance   Float    @default(0)
  address          String?
  
  status           String   @default("Active") // Active, On-Trip, Inactive
  
  trips            Trip[]
  vehicles         Vehicle[] @relation("VehicleDriver")
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Party {
  id               String   @id @default(uuid())
  companyName      String   @unique
  contactPerson    String?
  phone            String?
  email            String?
  gstNumber        String?
  address          String?
  
  outstandingBalance Float  @default(0)
  status           String   @default("Active")
  
  trips            Trip[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DieselLog {
  id               String   @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  
  date             DateTime @default(now())
  fuelStation      String?
  litres           Float
  ratePerLitre     Float
  totalCost        Float
  odometer         Int?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Expense {
  id               String   @id @default(uuid())
  category         String
  description      String?
  amount           Float
  paidBy           String?
  tripReference    String?
  date             DateTime @default(now())
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Invoice {
  id               String   @id @default(uuid())
  invoiceNumber    String   @unique
  date             DateTime @default(now())
  
  tripId           String
  trip             Trip     @relation(fields: [tripId], references: [id])
  
  subtotal         Float
  gstAmount        Float    @default(0)
  totalAmount      Float
  
  amountPaid       Float    @default(0)
  status           String   @default("Unpaid") // Unpaid, Partial, Paid
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
