datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

model Trip {
  id               String   @id @default(uuid())
  tripNo           String   @unique
  tripDate         DateTime @default(now())
  
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  
  partyId          String
  party            Party    @relation(fields: [partyId], references: [id])
  
  driverId         String?
  driver           Driver?  @relation(fields: [driverId], references: [id])

  from             String
  to               String
  material         String?
  sizeWeight       String?
  
  reportDate       DateTime?
  loadingDate      DateTime?
  unloadingDate    DateTime?
  
  billingType      String   @default("Fixed")
  freightAmount    Float    @default(0)
  
  dieselAmount     Float    @default(0)
  liquidDiesel     Float    @default(0)
  driverCash       Float    @default(0)
  labourCharges    Float    @default(0)
  permissionCharges Float   @default(0)
  toll             Float    @default(0)
  partyAdvance     Float    @default(0)
  driverAdvance    Float    @default(0)
  commission       Float    @default(0)
  maintenance      Float    @default(0)
  extraRunning     Float    @default(0)
  extraCharges     Float    @default(0)
  driverSavings    Float    @default(0)
  selfExpenses     Float    @default(0)
  balance          Float    @default(0)
  detentionTime    String?
  holdingDays      Int      @default(0)
  
  status           String   @default("Scheduled") // Scheduled, Loading, In Transit, Unloading, Completed
  podStatus        String   @default("Pending") // Pending, Received, Submitted
  paymentStatus    String   @default("Pending") // Pending, Partial, Paid
  
  route            String?
  notes            String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  invoices         Invoice[]
  directDrivers      DirectDriver[]
  driverAdvances     DriverAdvance[]
  driverChanges      DriverChangeHistory[]
  tollEntries        TollEntry[]
  maintenanceEntries MaintenanceEntry[]
  dieselEntries      DieselLog[]
  tripLinks          TripLink[]
}

model Vehicle {
  id               String   @id @default(uuid())
  vehicleNumber    String   @unique
  vehicleType      String
  capacity         String?
  
  currentKms       Int      @default(0)
  currentLocation  String?
  
  insuranceExpiry  DateTime?
  fitnessExpiry    DateTime?
  permitExpiry     DateTime?
  pollutionExpiry  DateTime?
  
  driverId         String?
  driver           Driver?  @relation("VehicleDriver", fields: [driverId], references: [id])
  
  status           String   @default("Active")
  notes            String?
  
  rcImagePath        String?
  insuranceImagePath String?
  fitnessImagePath   String?
  permitImagePath    String?

  
  trips            Trip[]
  dieselLogs       DieselLog[]
  maintenanceLogs  MaintenanceLog[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Driver {
  id               String   @id @default(uuid())
  driverName       String
  mobileNumber     String
  
  salary           Float    @default(0)
  advanceBalance   Float    @default(0)
  
  status           String   @default("Active") // Active, On-Trip, Inactive
  
  trips            Trip[]
  vehicles         Vehicle[] @relation("VehicleDriver")
  ledgers          DriverLedger[]
  advances         DriverAdvance[]
  settlements      DriverSettlement[]
  changesAsPrevious DriverChangeHistory[] @relation("PreviousDriver")
  changesAsNew     DriverChangeHistory[] @relation("NewDriver")
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Party {
  id               String   @id @default(uuid())
  companyName      String   @unique
  contactPerson    String?
  phone            String?
  
  outstandingBalance Float  @default(0)
  status           String   @default("Active")
  
  trips            Trip[]
  ledgers          PartyLedger[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DieselLog {
  id               String   @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  
  tripId           String?
  trip             Trip?    @relation(fields: [tripId], references: [id], onDelete: Cascade)
  
  date             DateTime @default(now())
  fuelStation      String?
  litres           Float
  ratePerLitre     Float
  totalCost        Float
  odometer         Int?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Expense {
  id               String   @id @default(uuid())
  category         String
  description      String?
  amount           Float
  paidBy           String?
  tripReference    String?
  date             DateTime @default(now())
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Invoice {
  id               String   @id @default(uuid())
  invoiceNumber    String   @unique
  date             DateTime @default(now())
  
  tripId           String
  trip             Trip     @relation(fields: [tripId], references: [id])
  
  subtotal         Float
  gstAmount        Float    @default(0)
  shortageAmount   Float    @default(0)
  damageAmount     Float    @default(0)
  totalAmount      Float
  
  amountPaid       Float    @default(0)
  status           String   @default("Unpaid") // Unpaid, Partial, Paid
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model MaintenanceLog {
  id               String   @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  
  date             DateTime @default(now())
  type             String   // Tyre, Oil, Repair, Spares, Other
  cost             Float    @default(0)
  odometer         Int?
  description      String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DriverLedger {
  id               String   @id @default(uuid())
  driverId         String
  driver           Driver   @relation(fields: [driverId], references: [id])
  
  date             DateTime @default(now())
  type             String   // Advance, Expense, Salary, Settlement, Personal
  amount           Float
  description      String?
  tripId           String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PartyLedger {
  id               String   @id @default(uuid())
  partyId          String
  party            Party    @relation(fields: [partyId], references: [id])
  
  date             DateTime @default(now())
  type             String   // Invoice, Payment, Adjustment
  amount           Float
  description      String?
  invoiceId        String?
  tripId           String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DirectDriver {
  id        String   @id @default(uuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driverName String
  createdAt DateTime @default(now())
}

model DriverAdvance {
  id        String   @id @default(uuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id])
  amount    Float
  date      DateTime @default(now())
  remarks   String?
  createdAt DateTime @default(now())
}

model DriverChangeHistory {
  id               String   @id @default(uuid())
  tripId           String
  trip             Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  previousDriverId String?
  previousDriver   Driver?  @relation("PreviousDriver", fields: [previousDriverId], references: [id])
  newDriverId      String?
  newDriver        Driver?  @relation("NewDriver", fields: [newDriverId], references: [id])
  changedAt        DateTime @default(now())
}

model DriverSettlement {
  id              String   @id @default(uuid())
  driverId        String
  driver          Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  amountGiven     Float    @default(0)
  amountReceived  Float    @default(0)
  balance         Float    @default(0)
  transactionDate DateTime @default(now())
  remarks         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TollEntry {
  id        String   @id @default(uuid())
  tripId    String
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tollName  String
  amount    Float
  date      DateTime @default(now())
  remarks   String?
  createdAt DateTime @default(now())
}

model MaintenanceEntry {
  id              String   @id @default(uuid())
  tripId          String
  trip            Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  maintenanceType String
  amount          Float
  date            DateTime @default(now())
  remarks         String?
  createdAt       DateTime @default(now())
}

model TripLink {
  id          String   @id @default(uuid())
  tripId      String
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  url         String
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

